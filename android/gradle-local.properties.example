# Copy this file to `android/gradle-local.properties` and replace the values
# with a working repo-local Gradle network or mirror setup.
#
# The file is loaded from `android/settings.gradle.kts` before plugin and
# dependency resolution, so `systemProp.*` values here override the broken
# global proxy setup when needed.

# Example direct connection:
# systemProp.http.proxyHost=
# systemProp.http.proxyPort=
# systemProp.https.proxyHost=
# systemProp.https.proxyPort=

# Example local proxy:
# systemProp.http.proxyHost=127.0.0.1
# systemProp.http.proxyPort=7890
# systemProp.https.proxyHost=127.0.0.1
# systemProp.https.proxyPort=7890
