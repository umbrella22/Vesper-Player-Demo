<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="vesper_player_external_route_background_light">#FFFFFFFF</color>
    <color name="vesper_player_external_route_background_dark">#FF202124</color>
    <color name="vesper_player_external_route_background_floating_dark">#FF303134</color>
    <color name="vesper_player_external_route_primary_light">#FF1A73E8</color>
    <color name="vesper_player_external_route_primary_dark">#FF8AB4F8</color>
    <color name="vesper_player_external_route_primary_dark_variant">#FF1A73E8</color>

    <!-- MediaRouter uses android:colorBackground for contrast calculations; keep every SDK-owned route theme opaque. -->
    <style name="VesperPlayerExternalRouteButtonTheme" parent="@style/VesperPlayerExternalRouteButtonTheme.Light" />

    <style name="VesperPlayerExternalRouteButtonTheme.Light" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@color/vesper_player_external_route_background_light</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:colorBackground">@color/vesper_player_external_route_background_light</item>
        <item name="android:isLightTheme">true</item>
        <item name="colorBackgroundFloating">@color/vesper_player_external_route_background_light</item>
        <item name="colorPrimary">@color/vesper_player_external_route_primary_light</item>
        <item name="colorPrimaryDark">@color/vesper_player_external_route_primary_light</item>
        <item name="colorAccent">@color/vesper_player_external_route_primary_light</item>
        <item name="android:colorAccent">@color/vesper_player_external_route_primary_light</item>
        <item name="mediaRouteTheme">@style/VesperPlayerExternalMediaRouteTheme.Light</item>
        <item name="mediaRouteButtonStyle">@style/Widget.MediaRouter.Light.MediaRouteButton</item>
    </style>

    <style name="VesperPlayerExternalRouteButtonTheme.Dark" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/vesper_player_external_route_background_dark</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:colorBackground">@color/vesper_player_external_route_background_dark</item>
        <item name="android:isLightTheme">false</item>
        <item name="colorBackgroundFloating">@color/vesper_player_external_route_background_floating_dark</item>
        <item name="colorPrimary">@color/vesper_player_external_route_primary_dark</item>
        <item name="colorPrimaryDark">@color/vesper_player_external_route_primary_dark_variant</item>
        <item name="colorAccent">@color/vesper_player_external_route_primary_dark</item>
        <item name="android:colorAccent">@color/vesper_player_external_route_primary_dark</item>
        <item name="mediaRouteTheme">@style/VesperPlayerExternalMediaRouteTheme.Dark</item>
        <item name="mediaRouteButtonStyle">@style/Widget.MediaRouter.MediaRouteButton</item>
    </style>

    <style name="VesperPlayerExternalMediaRouteTheme.Light" parent="Theme.MediaRouter.Light">
        <item name="android:colorBackground">@color/vesper_player_external_route_background_light</item>
        <item name="android:windowBackground">@color/vesper_player_external_route_background_light</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:isLightTheme">true</item>
        <item name="colorBackgroundFloating">@color/vesper_player_external_route_background_light</item>
        <item name="colorPrimary">@color/vesper_player_external_route_primary_light</item>
        <item name="colorPrimaryDark">@color/vesper_player_external_route_primary_light</item>
        <item name="colorAccent">@color/vesper_player_external_route_primary_light</item>
        <item name="android:colorAccent">@color/vesper_player_external_route_primary_light</item>
    </style>

    <style name="VesperPlayerExternalMediaRouteTheme.Dark" parent="Theme.MediaRouter">
        <item name="android:colorBackground">@color/vesper_player_external_route_background_dark</item>
        <item name="android:windowBackground">@color/vesper_player_external_route_background_dark</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:isLightTheme">false</item>
        <item name="colorBackgroundFloating">@color/vesper_player_external_route_background_floating_dark</item>
        <item name="colorPrimary">@color/vesper_player_external_route_primary_dark</item>
        <item name="colorPrimaryDark">@color/vesper_player_external_route_primary_dark_variant</item>
        <item name="colorAccent">@color/vesper_player_external_route_primary_dark</item>
        <item name="android:colorAccent">@color/vesper_player_external_route_primary_dark</item>
    </style>
</resources>
