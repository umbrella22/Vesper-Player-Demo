#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<EOF >&2
Usage: scripts/vesper <group> <command> [args...]

Groups:
  ffmpeg  --platform android|ios|all [options]
  ffi      generate | sync | verify | c-host-smoke
  android  jni | aar | remux-plugin | source-normalizer-plugin | frame-processor-plugin | stage-release | sample-apks
  ios      ffi | remux-plugin | source-normalizer-plugin | frame-processor-plugin | ffmpeg-runtime-release | stage-remux-plugin-release | stage-source-normalizer-plugin-release | stage-frame-processor-plugin-release | kit-xcframework | embed-remux-plugin | stage-release | sync-bridge-shim | verify-bridge-shim
  desktop  ensure-ffmpeg | verify-remux | verify-decoder-diagnostics | verify-decoder-d3d11 | verify-decoder-videotoolbox
  mobile   verify-no-remux
  flutter  stage-pub | pub-dry-run | pub-publish | local-overrides | verify-android-plugin
  release  notes | set-version | prepare-from-tag | metadata-from-tag | verify-version | verify-current
  contract verify
EOF
}

if [[ "${1:-}" == "ffmpeg" ]]; then
  shift
  exec "$SCRIPT_DIR/ffmpeg/build.sh" "$@"
fi

if [[ $# -lt 2 ]]; then
  usage
  exit 1
fi

group="$1"
command="$2"
shift 2

case "$group:$command" in
  ffi:generate)
    exec "$SCRIPT_DIR/ffi/generate-player-ffi-header.sh" "$@"
    ;;
  ffi:sync)
    exec "$SCRIPT_DIR/ffi/sync-player-ffi-header.sh" "$@"
    ;;
  ffi:verify)
    exec "$SCRIPT_DIR/ffi/verify-player-ffi-header.sh" "$@"
    ;;
  ffi:c-host-smoke)
    exec "$SCRIPT_DIR/ffi/run-c-host-smoke.sh" "$@"
    ;;
  android:jni)
    exec "$SCRIPT_DIR/android/build-vesper-player-kit-jni.sh" "$@"
    ;;
  android:aar)
    exec "$SCRIPT_DIR/android/build-vesper-player-kit-aar.sh" "$@"
    ;;
  android:remux-plugin)
    exec "$SCRIPT_DIR/android/build-player-remux-ffmpeg-plugin.sh" "$@"
    ;;
  android:source-normalizer-plugin)
    exec "$SCRIPT_DIR/android/build-player-source-normalizer-ffmpeg-plugin.sh" "$@"
    ;;
  android:frame-processor-plugin)
    exec "$SCRIPT_DIR/android/build-player-frame-processor-diagnostic-plugin.sh" "$@"
    ;;
  android:stage-release)
    exec "$SCRIPT_DIR/android/stage-vesper-player-kit-release.sh" "$@"
    ;;
  android:sample-apks)
    exec "$SCRIPT_DIR/android/stage-sample-apks.sh" "$@"
    ;;
  ios:ffi)
    exec "$SCRIPT_DIR/ios/build-player-ffi-xcframework.sh" "$@"
    ;;
  ios:remux-plugin)
    exec "$SCRIPT_DIR/ios/build-player-remux-ffmpeg-plugin.sh" "$@"
    ;;
  ios:source-normalizer-plugin)
    exec "$SCRIPT_DIR/ios/build-player-source-normalizer-ffmpeg-plugin.sh" "$@"
    ;;
  ios:frame-processor-plugin)
    exec "$SCRIPT_DIR/ios/build-player-frame-processor-diagnostic-plugin.sh" "$@"
    ;;
  ios:ffmpeg-runtime-release)
    exec "$SCRIPT_DIR/ios/stage-player-ffmpeg-runtime-release.sh" "$@"
    ;;
  ios:stage-remux-plugin-release)
    exec "$SCRIPT_DIR/ios/stage-player-remux-ffmpeg-plugin-release.sh" "$@"
    ;;
  ios:stage-source-normalizer-plugin-release)
    exec "$SCRIPT_DIR/ios/stage-player-source-normalizer-ffmpeg-plugin-release.sh" "$@"
    ;;
  ios:stage-frame-processor-plugin-release)
    exec "$SCRIPT_DIR/ios/stage-player-frame-processor-diagnostic-plugin-release.sh" "$@"
    ;;
  ios:kit-xcframework)
    exec "$SCRIPT_DIR/ios/build-vesper-player-kit-xcframework.sh" "$@"
    ;;
  ios:embed-remux-plugin)
    exec "$SCRIPT_DIR/ios/embed-player-remux-ffmpeg-plugin.sh" "$@"
    ;;
  ios:stage-release)
    exec "$SCRIPT_DIR/ios/stage-vesper-player-kit-release.sh" "$@"
    ;;
  ios:sync-bridge-shim)
    exec "$SCRIPT_DIR/ios/sync-vesper-player-kit-bridge-shim.sh" "$@"
    ;;
  ios:verify-bridge-shim)
    exec "$SCRIPT_DIR/ios/verify-vesper-player-kit-bridge-shim.sh" "$@"
    ;;
  desktop:ensure-ffmpeg)
    exec "$SCRIPT_DIR/desktop/ensure-ffmpeg.sh" "$@"
    ;;
  desktop:verify-remux)
    exec "$SCRIPT_DIR/desktop/verify-player-remux-ffmpeg.sh" "$@"
    ;;
  desktop:verify-decoder-diagnostics)
    exec "$SCRIPT_DIR/desktop/verify-decoder-plugin-diagnostics.sh" "$@"
    ;;
  desktop:verify-decoder-d3d11)
    exec "$SCRIPT_DIR/desktop/verify-decoder-plugin-v2-d3d11.sh" "$@"
    ;;
  desktop:verify-decoder-videotoolbox)
    exec "$SCRIPT_DIR/desktop/verify-decoder-plugin-v2-videotoolbox.sh" "$@"
    ;;
  mobile:verify-no-remux)
    exec "$SCRIPT_DIR/mobile/verify-host-kit-without-player-remux-ffmpeg.sh" "$@"
    ;;
  flutter:stage-pub)
    exec "$SCRIPT_DIR/flutter/stage-pub-packages.sh" "$@"
    ;;
  flutter:pub-dry-run)
    exec "$SCRIPT_DIR/flutter/pub-dry-run.sh" "$@"
    ;;
  flutter:pub-publish)
    exec "$SCRIPT_DIR/flutter/publish-pub-packages.sh" "$@"
    ;;
  flutter:local-overrides)
    exec "$SCRIPT_DIR/flutter/write-local-overrides.sh" "$@"
    ;;
  flutter:verify-android-plugin)
    exec "$SCRIPT_DIR/flutter/verify-android-plugin.sh" "$@"
    ;;
  release:notes)
    exec "$SCRIPT_DIR/release/generate-notes.sh" "$@"
    ;;
  release:set-version)
    exec "$SCRIPT_DIR/release/version.sh" set "$@"
    ;;
  release:prepare-from-tag)
    exec "$SCRIPT_DIR/release/version.sh" prepare-from-tag "$@"
    ;;
  release:metadata-from-tag)
    exec "$SCRIPT_DIR/release/version.sh" metadata-from-tag "$@"
    ;;
  release:verify-version)
    exec "$SCRIPT_DIR/release/version.sh" verify "$@"
    ;;
  release:verify-current)
    exec "$SCRIPT_DIR/release/version.sh" verify-current "$@"
    ;;
  contract:verify)
    exec "$SCRIPT_DIR/verify-contract-fixtures.sh" "$@"
    ;;
  *)
    usage
    exit 1
    ;;
esac
